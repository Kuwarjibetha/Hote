<%- layout("/layouts/boilerplate") %>

    <div class="container mt-4">

        
        <div class="mb-4"> <!-- welcome message -->
            <h3 class="fw-bold">Welcome, <%= currUser.username %>! 👋</h3>
            <p class="text-muted">Here's your property overview</p>
        </div>

        
        <div class="row g-3 mb-4"> <!-- stats cards row -->

            
            <div class="col-6 col-md-3"><!-- total listings -->
                <div class="card text-white text-center p-3 rounded-4 border-0" style="background: #e74c3c;">
                    <div style="font-size: 2rem;">🏠</div>
                    <h3 class="fw-bold mb-0">
                        <%= totalListings %>
                    </h3>
                    <small>Total Listings</small>
                </div>
            </div>

            <!-- total bookings -->
            <div class="col-6 col-md-3">
                <div class="card text-white text-center p-3 rounded-4 border-0" style="background: #6c5ce7;">
                    <div style="font-size: 2rem;">📅</div>
                    <h3 class="fw-bold mb-0">
                        <%= totalBookings %>
                    </h3>
                    <small>Total Bookings</small>
                </div>
            </div>




            <!-- total revenue -->
            <div class="col-6 col-md-3">
                <div class="card text-white text-center p-3 rounded-4 border-0" style="background: #00b894;">
                    <div style="font-size: 2rem;">💰</div>
                    <h3 class="fw-bold mb-0">
                        ₹<%= totalRevenue.toLocaleString("en-in") %>
                    </h3>
                    <small>Total Revenue</small>
                </div>
            </div>

            <!-- total guests -->
            <div class="col-6 col-md-3">
                <div class="card text-white text-center p-3 rounded-4 border-0" style="background: #0984e3;">
                    <div style="font-size: 2rem;">👥</div>
                    <h3 class="fw-bold mb-0">
                        <%= totalGuests %>
                    </h3>
                    <small>Total Guests</small>
                </div>
            </div>

        </div>

        <!-- recent bookings table -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3">📋 Recent Bookings</h5>

                <% if (recentBookings.length===0) { %>
                    <div class="text-center py-4">
                        <div style="font-size: 3rem;">📭</div>
                        <p class="text-muted mt-2">No bookings yet!</p>
                    </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Guest Name</th>
                                        <th>Property</th>
                                        <th>Check-in</th>
                                        <th>Check-out</th>
                                        <th>Guests</th>
                                        <th>Type</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% for (let booking of recentBookings) { %>
                                        <tr>
                                            <td>
                                                <p class="fw-semibold mb-0">
                                                    <%= booking.guestName %>
                                                </p>
                                                <small class="text-muted">
                                                    <%= booking.guestPhone %>
                                                </small>
                                            </td>
                                            <td>
                                                <%= booking.listing.title %>
                                            </td>
                                            <td>
                                                <%= booking.checkIn.toDateString() %>
                                            </td>
                                            <td>
                                                <%= booking.checkOut.toDateString() %>
                                            </td>
                                            <td>
                                                <%= booking.guests %>
                                            </td>
                                            <td>
                                                <% if (booking.travelType==="solo" ) { %>
                                                    <span class="badge bg-info">Solo</span>
                                                    <% } else if (booking.travelType==="couple" ) { %>
                                                        <span class="badge bg-danger">Couple</span>
                                                        <% } else if (booking.travelType==="family" ) { %>
                                                            <span class="badge bg-success">Family</span>
                                                            <% } else if (booking.travelType==="bachelors" ) { %>
                                                                <span class="badge bg-warning">Bachelors</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-secondary">—</span>
                                                                    <% } %>
                                            </td>
                                            <td class="text-danger fw-bold">
                                                ₹<%= booking.totalPrice.toLocaleString("en-in") %>
                                            </td>
                                        </tr>
                                        <% } %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>

            </div>
        </div>

        <!-- My Listings -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">🏡 My Listings</h5>
                    <a href="/listings/new" class="btn btn-danger btn-sm rounded-3">
                        + Add New
                    </a>
                </div>

                <% if (myListings.length===0) { %>
                    <div class="text-center py-4">
                        <div style="font-size: 3rem;">🏠</div>
                        <p class="text-muted mt-2">No listings yet!</p>
                        <a href="/listings/new" class="btn btn-danger btn-sm rounded-3">
                            Add First Listing
                        </a>
                    </div>
                    <% } else { %>
                        <div class="row g-3">
                            <% for (let listing of myListings) { %>
                                <div class="col-md-4">
                                    <div class="card border rounded-4 overflow-hidden h-100 ">
                                        <img src="<%= listing.image.url %>" class="card-img-top main-card" alt="listing" />
                                        <div class="card-body p-3">
                                            <p class="fw-bold mb-1">
                                                <%= listing.title %>
                                            </p>
                                            <p class="text-muted mb-1" style="font-size: 0.85rem;">
                                                📍 <%= listing.location %>, <%= listing.country %>
                                            </p>
                                            <p class="text-danger fw-bold mb-2">
                                                ₹<%= listing.price.toLocaleString("en-in") %>/night
                                            </p>
                                            <p class="text-muted mb-2" style="font-size: 0.85rem;">
                                                👥 Max: <%= listing.maxPersons %> persons
                                            </p>
                                            <div class="d-flex gap-2">
                                                <a href="/listings/<%= listing._id %>"
                                                    class="btn btn-outline-danger btn-sm rounded-3 w-100">
                                                    View
                                                </a>
                                                <a href="/listings/<%= listing._id %>/edit"
                                                    class="btn btn-outline-dark btn-sm rounded-3 w-100">
                                                    Edit
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                        </div>
                        <% } %>

            </div>
        </div>

    </div>