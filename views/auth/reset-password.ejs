<%- layout("/layouts/boilerplate") %>
<div class="row mt-5 justify-content-center">
  <div class="col-md-5 col-sm-8">
    <div class="card border-0 shadow-sm rounded-4 p-4">

      <div class="text-center mb-4">
        <div style="font-size:3rem;">🔑</div>
        <h3 class="fw-bold mb-1">Reset Password</h3>
        <p class="text-muted">
          Enter your new password below.
        </p>
      </div>

      <!-- Flash Messages -->
      <% if (error && error.length > 0) { %>
        <div class="alert alert-danger rounded-3 mb-3">
          <%= error %>
        </div>
      <% } %>

      <form action="/reset-password/<%= token %>" method="POST">

        <div class="mb-3">
          <label class="form-label fw-semibold">New Password</label>
          <input
            type="password"
            name="password"
            class="form-control rounded-3"
            placeholder="Enter new password"
            minlength="6"
            required
          />
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold">Confirm Password</label>
          <input
            type="password"
            id="confirmPassword"
            class="form-control rounded-3"
            placeholder="Confirm new password"
            minlength="6"
            required
          />
          <div id="matchError" class="text-danger mt-1" style="font-size:0.85rem; display:none;">
            ❌ Passwords do not match!
          </div>
        </div>

        <button
          id="submitBtn"
          class="btn btn-danger w-100 py-2 rounded-3 fw-bold">
          Reset Password ✅
        </button>

      </form>

    </div>
  </div>
</div>

<script>
  


  // Check passwords match before submit
  const confirmInput = document.getElementById("confirmPassword");
  const submitBtn = document.getElementById("submitBtn");
  const matchError = document.getElementById("matchError");

  confirmInput.addEventListener("input", function() {
    const password = document.querySelector("input[name='password']").value;
    if (this.value && this.value !== password) {
      matchError.style.display = "block";
      submitBtn.disabled = true;
    } else {
      matchError.style.display = "none";
      submitBtn.disabled = false;
    }
  });
</script>